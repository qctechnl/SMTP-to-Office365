# =============================================================================
# General
# =============================================================================

# Hostname used in SMTP EHLO/HELO and mail headers
RELAY_HOSTNAME=mail.example.com

# Networks allowed to relay mail without authentication (space-separated CIDR)
RELAY_ALLOWED_NETWORKS=10.0.0.0/8

# Space-separated list of specific mailbox addresses this relay serves
# (no domain wildcards — each must be an existing mailbox).
# Mail from an address not in this list is rejected by Postfix at MAIL FROM time.
# Each address must be a member of the RBAC management scope group in Exchange
# Online, granted via the "Application Mail Full Access" / "Application Mail.Send"
# role (see README step 4). No tenant-wide Entra ID consent is used.
#
# Examples:
#   Single address: relay@example.com
#   Multiple:       relay@example.com noreply@example.com invoices@example.com
RELAY_FROM_ADDRESSES=relay@example.com

# =============================================================================
# Ports
# =============================================================================

# Host IP address to bind on (default: all interfaces)
LISTEN_ADDRESS=0.0.0.0

# Host port for plain SMTP (default: 25)
SMTP_PORT=25

# Host port for SMTP submission with TLS + SASL (default: 587)
SUBMISSION_PORT=587

# =============================================================================
# Inbound TLS
# =============================================================================

# TLS level for port 25 (plain SMTP from local applications)
# none     = TLS disabled
# may      = TLS optional (default)
# encrypt  = TLS mandatory
SMTP_TLS_LEVEL=may

# TLS level for port 587 (submission, typically used with SASL authentication)
# none     = TLS disabled
# may      = TLS optional (default)
# encrypt  = TLS mandatory (recommended when SASL is used)
SUBMISSION_TLS_LEVEL=may

# Reverse DNS (PTR) lookup of the connecting client's IP address.
# Only affects the Received: header and mail log — no access restriction
# in this relay depends on the client hostname.
# yes = enabled (default, standard Postfix behaviour)
# no  = disabled — use this if legacy/isolated senders on networks without
#       usable DNS cause connections to stall or fail on this lookup
SMTP_PEERNAME_LOOKUP=yes

# =============================================================================
# Logging
# =============================================================================

# Log verbosity
# error   = errors only
# info    = inbound TLS summaries + one line per delivered message (default)
# debug   = full inbound TLS details + Graph API request/response logging
# verbose = same as debug + access token logged on every token fetch (sensitive — do not use in production)
LOG_LEVEL=info

# =============================================================================
# Entra ID App Registration
# =============================================================================

# Azure AD tenant ID (found in Entra ID > Overview)
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App registration client ID
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Authentication type: 'certificate' or 'secret'
ENTRA_AUTH_TYPE=secret

# --- Client secret authentication (required when ENTRA_AUTH_TYPE=secret) ---
ENTRA_CLIENT_SECRET=your-client-secret-here

# --- Certificate authentication (required when ENTRA_AUTH_TYPE=certificate) ---
# Path inside the container to the Entra ID client certificate.
# This certificate authenticates the relay to Microsoft Graph — it is NOT the
# same as the inbound SMTP TLS certificate (see SMTP_TLS_CERT_PATH below).
# Map host files via CERTS_DIR below.
# ENTRA_CERT_PATH=/certs/entra.crt
# ENTRA_KEY_PATH=/certs/entra.key

# =============================================================================
# Certificates
# =============================================================================

# Host directory mounted as /certs inside the container.
# Place all certificates here: the inbound SMTP TLS certificate and (when using
# certificate authentication) the Entra ID client certificate.
CERTS_DIR=./certs

# Path inside the container to the inbound SMTP TLS certificate.
# This encrypts SMTP connections from local applications to this relay.
# It is NOT the same as the Entra ID client certificate (see ENTRA_CERT_PATH above).
#
# Generate a self-signed certificate (the SAN must match the hostname/IP
# senders actually use to connect — see README for details):
#   openssl req -x509 -newkey rsa:4096 -keyout ./certs/smtp.key \
#               -out ./certs/smtp.crt -days 3650 -nodes -subj "/CN=mail.example.com" \
#               -addext "subjectAltName=DNS:mail.example.com" \
#               -addext "keyUsage=digitalSignature,keyEncipherment" \
#               -addext "extendedKeyUsage=serverAuth"
SMTP_TLS_CERT_PATH=/certs/smtp.crt
SMTP_TLS_KEY_PATH=/certs/smtp.key

# =============================================================================
# Inbound SASL user database
# =============================================================================

# Host directory where sasldb2 is stored (survives container recreation)
# Manage users with:
#   docker exec -it smtp-to-office365 manage-users.sh add <username> <domain>
#   docker exec -it smtp-to-office365 manage-users.sh delete <username> <domain>
#   docker exec -it smtp-to-office365 manage-users.sh list
SASLDB_DIR=./sasldb

# =============================================================================
# Graph delivery options
# =============================================================================

# Whether relay-sent mail appears in each sender's Sent Items folder in Office 365.
# false = no (default, avoids cluttering automation mailboxes)
# true  = yes (provides an audit trail per mailbox visible in Outlook/OWA)
GRAPH_SAVE_TO_SENT_ITEMS=false

# Whether to support large attachments (> 3 MB) via the Graph draft + chunked upload flow.
# true  = enabled (default) — attachments > 3 MB are sent via a draft + upload session.
#         Requires the RBAC role "Application Mail Full Access" (Mail.Send + Mail.ReadWrite).
# false = disabled — always uses the simple sendMail path; the send-only role
#         "Application Mail.Send" is sufficient.
#         Attachments that exceed Graph's ~4 MB per-request limit will bounce with a permanent error.
GRAPH_LARGE_ATTACHMENTS=true
